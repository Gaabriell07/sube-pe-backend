# ─── Variables de entorno — copia esto en Render > Environment ───────────────
# NO subas el .env real a GitHub. Este archivo sí puede subirse.

# Base de datos Supabase (con pgbouncer para connection pooling)
DATABASE_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true"

# URL directa (solo para migraciones con prisma migrate deploy)
DIRECT_URL="postgresql://postgres.<project>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# Supabase
SUPABASE_URL="https://<project>.supabase.co"
SUPABASE_ANON_KEY="sb_publishable_..."

# JWT (cámbialo por un string largo y aleatorio en producción)
JWT_SECRET="cambia_esto_por_algo_muy_secreto_en_produccion"

# Puerto (Render lo asigna automáticamente, no lo cambies)
PORT=3000

# Entorno
NODE_ENV="production"

# CORS: URLs separadas por coma de los frontends que pueden llamar a la API
# Ejemplo: https://subepe-admin.vercel.app,https://subepe-app.vercel.app
ALLOWED_ORIGINS="https://tu-admin.vercel.app,https://tu-app.vercel.app"
